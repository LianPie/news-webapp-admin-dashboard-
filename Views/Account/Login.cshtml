<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ورود به پنل</title>
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css">
    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f8f9fa; /* Light gray background */
        }

        .login-container {
            display: flex;
            height: 100vh; /* Full viewport height */
        }

        .login-image {
            flex: 1;
            background: url('https://via.placeholder.com/800x600') no-repeat center center; /* Placeholder image */
            background-size: cover;
            border-top-left-radius: 30px;
            border-bottom-left-radius: 30px;
        }
        .login-form {
            height: 100%; /* Full width of form */

            flex: 1;
            max-width: 400px; /* Max width of form */
            padding: 30px; /* Padding around form */
            background: #90b6f3; /* White background for the form */
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.1); /* Light shadow around the form */
        }
        .in {
            width: 100%; /* Full width of form */
            height: 70%; /* Full width of form */
            display: flex;
            align-items: center;
            justify-content: right
        }

    </style>
</head>

<body>

    <div class="container-fluid login-container" dir="ltr">
        <div class="login-image"></div>
        <div class="login-form" >
            <h2 dir="rtl">ورود به پنل</h2>
            <div class="in">
                <form action="/Account/Login" method="post" dir="rtl" class="form-check">
                    @Html.AntiForgeryToken()
                    <!-- Update the action URL accordingly -->
                    <div class="mb-3">
                        <label for="username" class="form-label">نام کاربری</label>
                        <input type="text" class="form-control" id="username" name="usename" required>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">رمز عبور</label>
                        <input type="password" class="form-control" id="password" name="password" required>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Login</button>

                </form>

            </div>
            
        </div>
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.min.js"></script>
</body>

</html>
