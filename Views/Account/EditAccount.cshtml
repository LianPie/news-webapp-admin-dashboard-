@model newsWebapp.Models.user

@{
    Layout = "~/Views/_Layout.cshtml";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>ویرایش پروفایل</title>
</head>
<body>
    <div id="mainContent" class="content container" style="margin-right: 0;">

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

        <div class="form-horizontal">

            <div class="card textc col-sm-9 mb-6 mb-sm-0">
                <div class="card-header">
                    اطلاعات پروفایل
                </div>
                <div class="card-body">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    @Html.HiddenFor(model => model.ID)

                    <div class="form-group">
                        نام کاربری
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.usename, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.usename, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group">
                        رمز عبور
                        <div class="col-md-10">
                            <input type="password" name="password" class="form-control" />
                            @Html.ValidationMessageFor(model => model.password, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group">
                        نام
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.displayname, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.displayname, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
                <div class="card-footer text-body-secondary">
                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">

                            <input type="submit" value="ذخیره" class="btn btn-success" />
                            @Html.ActionLink("بازگشت به پروفایل", "index", null, new { @class = "btn btn-primary" })

                        </div>
                    </div>
                </div>
            </div>
           
           
        </div>
        }

    </div>
</body>
</html>
