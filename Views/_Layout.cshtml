<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>_Layout</title>

    <link href="~/assets/css/bootstrap.rtl.min.css" rel="stylesheet" />
    @RenderSection("head", false)
    <style>

        .offcanvas {
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3); /* Larger shadow */
        }
        .content {
            transition: margin-right .5s ease;
            padding: 20px;
        }

        /* Remove border from accordion items */
        .accordion-button {
            border: none;
            box-shadow: none;
            color: #1a1c1ded;
        }
        .accordion-item {
            border: none;
            margin-bottom: 0.5rem;
        }
        .accordion-button:not(.collapsed) {
            background-color: #b3ffb9; /* Background color when expanded */
            color: #153116;
            font: bold;
        }

        /* Style for submenu items */
        .submenu-item {
            display: block;
            padding: 0.5rem 1rem;
            color: #1a1c1ded; /* Link color */
            text-decoration: none;
            border-radius: 0.25rem; /* Rounded corners */
        }

            .submenu-item:hover {
                background-color: #e9ecef; /* Background color on hover */
                color: #314222; /* Darker link color on hover */
                text-decoration: none;
            }
    </style>
</head>
<body>
    <nav class="navbar" style=" background-color: #b3ffb9">
        <div class="container">
            <button class="btn btn-img" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasRight" aria-controls="offcanvasRight" title="Toggle Offcanvas">
                <img src="~/assets/icons/menuburger.png" alt="Toggle Offcanvas" />
            </button>
            <span class="navbar-brand mb-0 h1">?What's new</span>
        </div>
    </nav>
    @RenderBody()


    <div class="offcanvas offcanvas-start show" tabindex="-1" id="offcanvasRight" aria-labelledby="offcanvasRightLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="offcanvasRightLabel">Offcanvas right</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">


            <div class="accordion" id="accordionExample1">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#dashboard" aria-expanded="true" aria-controls="dashboard">
                            داشبورد
                        </button>
                    </h2>
                    <div id="dashboard" class="accordion-collapse collapse show" data-bs-parent="#accordionExample1">
                        <div class="accordion-body">
                            @Html.ActionLink("صفحه اصلی", "Index", "Home", new { area = "" }, new { @class = "nav-link submenu-item" })
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion" id="accordionExample2">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#account" aria-expanded="true" aria-controls="account">
                            حساب کاربری
                        </button>
                    </h2>
                    <div id="account" class="accordion-collapse collapse" data-bs-parent="#accordionExample2">
                        <div class="accordion-body">
                            @Html.ActionLink("پروفایل", "Index", "Account", new { area = "" }, new { @class = "nav-link submenu-item" })
                            @Html.ActionLink("ویرایش پروفایل", "EditAccount", "Account", new { area = "" }, new { @class = "nav-link submenu-item" })
                            @Html.ActionLink("حذف حساب", "DeleteAccount", "Account", new { area = "" }, new { @class = "nav-link submenu-item" })
                        </div>
                    </div>
                </div>
            </div>


            <div class="accordion" id="accordionExample3">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#news" aria-expanded="true" aria-controls="news">
                            اخبار
                        </button>
                    </h2>
                    <div id="news" class="accordion-collapse collapse show" data-bs-parent="#accordionExample3">
                        <div class="accordion-body">
                            @Html.ActionLink("لیست خبار", "Index", "News", new { area = "" }, new { @class = "nav-link submenu-item" })
                            @Html.ActionLink("خبر جدید", "Create", "News", new { area = "" }, new { @class = "nav-link submenu-item" })
                            @Html.ActionLink("دسته بندی", "Index", "Categories", new { area = "" }, new { @class = "nav-link submenu-item" })
                            @Html.ActionLink("برچسب", "Index", "Tags", new { area = "" }, new { @class = "nav-link submenu-item" })



                        </div>
                    </div>
                </div>
            </div>


            <div class="accordion" id="accordionExample4">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ticket" aria-expanded="true" aria-controls="ticket">
                            تیکت
                        </button>
                    </h2>
                    <div id="ticket" class="accordion-collapse collapse" data-bs-parent="#accordionExample4">
                        <div class="accordion-body">
                            @Html.ActionLink("تیکت جدید", "send", "Ticket", new { area = "" }, new { @class = "nav-link submenu-item" })
                            @Html.ActionLink("همه تیکت ها", "inex", "Ticket", new { area = "" }, new { @class = "nav-link submenu-item" })
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const offcanvasElement = document.getElementById('offcanvasRight');
            const mainContent = document.getElementById('mainContent');

            const offcanvas = new bootstrap.Offcanvas(offcanvasElement, {
                backdrop: false  // Disable the backdrop
            });

            offcanvasElement.addEventListener('show.bs.offcanvas', function () {
                const offcanvasWidth = offcanvasElement.offsetWidth;
                mainContent.style.marginRight = `${offcanvasWidth}px`;

                mainContent.style.paddingLeft = `${offcanvasWidth}px`;
            });

            offcanvasElement.addEventListener('hide.bs.offcanvas', function () {
                mainContent.style.marginRight = '0';
                mainContent.style.paddingLeft = `0`;

            });
        });
    </script>
    @RenderSection("script", false)
</body>
</html>
